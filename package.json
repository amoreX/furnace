{
  "name": "furnace",
  "version": "0.0.0",
  "description": "A from-scratch harness for agentic coding.",
  "type": "module",
  "bin": {
    "furnace": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test"
  },
  "keywords": [
    "ai",
    "agent",
    "coding-agent",
    "cli",
    "tui"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.2",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
